# Salt Frame Visuals — variables de entorno (no commitear valores reales)

# URL pública del sitio
NEXT_PUBLIC_SITE_URL=https://saltframevisuals.com

# ── Backoffice (Payload CMS) ───────────────────────────────────────────────
# Clave de cifrado de sesiones (alta entropía). Generar: openssl rand -hex 32
PAYLOAD_SECRET=

# Base de datos:
#  - Local (dev/verificación): SQLite -> file:./cms.db
#  - Producción: Railway Postgres -> postgres://user:pass@host:port/db
DATABASE_URI=file:./cms.db

# Servir el contenido desde el CMS (true) o desde los archivos estáticos (vacío).
# Activar SOLO después de sembrar el contenido en Payload.
# USE_CMS=true

# ── Medios en producción (Cloudinary) ──────────────────────────────────────
# En dev los uploads van a disco (public/media/cms). En prod (Vercel es
# efímero) se conecta Cloudinary. Ver docs/03-BACKOFFICE.md.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Email (Resend) — notificación de leads / reset de password ─────────────
# RESEND_API_KEY=
