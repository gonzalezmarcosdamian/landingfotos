# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
/test-results
/playwright-report
/.nyc_output

# Next.js
/.next/
/out/
/build
next-env.d.ts

# Production
/dist

# Misc
.DS_Store
*.pem
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment variables (NEVER commit secrets)
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# Media — originales pesados no se versionan (ver docs/05-MEDIA-GUIDE.md)
/public/media/raw/**
!/public/media/raw/**/
!/public/media/raw/**/.gitkeep
# Videos optimizados pesados: servir desde storage externo, no commitear
/public/media/optimized/**/*.mp4
/public/media/optimized/**/*.webm
/public/media/optimized/**/*.mov
# Videos web del hero: se despliegan vía Vercel CLI (.vercelignore), no se versionan
/public/hero/*.mp4
/public/hero/*.webm
# Videos de proyectos (cinematic): se despliegan vía Vercel, no se versionan en git
/public/projects/*.mp4
/public/projects/*.webm

# TypeScript
*.tsbuildinfo

# IDE / OS
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp

.vercel
